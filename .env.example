# GitHub Personal Access Token
# Create one at: https://github.com/settings/tokens
# Required scopes: read:user, repo (for private repo stats, optional)
GITHUB_TOKEN=your_github_token_here

# Telegram bot for the "Work With Me" inquiry form
# 1. Message @BotFather on Telegram, /newbot, copy the token
# 2. Message your new bot once (it can't DM you first), then get your chat id:
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates  → message.chat.id
TELEGRAM_BOT_TOKEN=123456:your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
